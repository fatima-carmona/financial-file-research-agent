# --- LLM provider (chat/reasoning — Analyst and Critic agents) ---
# Set which provider to use, then supply the matching key
# google = Gemini API (recommended: free tier, no credit card required)
LLM_PROVIDER=google          # openai | anthropic | google
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Model names
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-4-6
GOOGLE_MODEL=gemini-2.5-flash

# --- Embedding provider (ingestion + retrieval) ---
# Separate from LLM_PROVIDER on purpose: embedding needs hundreds of calls
# per document, and Gemini's free embedding quota is much stricter than its
# chat quota. Default is "local" — runs on your machine, no API calls, no
# rate limits, completely free. Only change this if you specifically want
# hosted embeddings.
EMBEDDING_PROVIDER=local      # local | google | openai
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001

# --- Database (matches docker-compose defaults) ---
POSTGRES_USER=filing_agent
POSTGRES_PASSWORD=filing_agent_dev_password
POSTGRES_DB=filings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- SEC EDGAR ---
# EDGAR requires a descriptive User-Agent with contact info on every request
SEC_EDGAR_USER_AGENT="Your Name your.email@example.com"

# --- App ---
LOG_LEVEL=INFO
